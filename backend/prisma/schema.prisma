generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  ADMIN
  BUSINESS
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
}

enum BusinessCategory {
  FOOD
  RETAIL
  BEAUTY
  SERVICES
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum ItemStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMode {
  NONE
  SIMPLE
  RECIPE_BASED
}

enum IngredientStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  INVENTORY_INITIAL
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALE_RETURN
  ADJUSTMENT_POSITIVE
  ADJUSTMENT_NEGATIVE
}

enum InventoryReferenceType {
  ORDER
  ORDER_ITEM
  MANUAL
  PURCHASE_MANUAL
}

enum AccountingMovementOriginType {
  MANUAL
  ORDER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum OrderStatus {
  DRAFT
  SENT
  CANCELLED
  COMPLETED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum SaleOrigin {
  MANUAL
  PUBLIC_STORE
}

//
// MODELOS CORE
//

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole

  // MVP: 1 cuenta BUSINESS por negocio.
  // ADMIN queda sin negocio (businessId = null).
  businessId String?   @unique
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Business {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  fiscalId      String
  phoneWhatsapp String
  logoUrl       String?
  status        BusinessStatus @default(ACTIVE)
  inactivatedAt DateTime?

  // Business classification used to drive inventory defaults and module behavior.
  businessCategory BusinessCategory @default(RETAIL)

  // 1–1 (derivada del @unique en User.businessId)
  user User?

  items        Item[]
  orders       Order[]
  reservations Reservation[]

  schedules           ServiceScheduleWindow[]
  blocks              ServiceScheduleBlock[]
  accountingMovements AccountingMovement[]

  // Physical stock inputs owned by this business.
  ingredients        Ingredient[]
  // Tenant-scoped item-to-ingredient consumption rules.
  recipes            Recipe[]
  // Tenant-scoped Kardex entries for ingredient stock.
  inventoryMovements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessCategory])
}

model Item {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type   ItemType
  status ItemStatus @default(ACTIVE)

  // Defines whether this sellable item consumes no stock, one ingredient, or recipe ingredients.
  inventoryMode InventoryMode @default(NONE)

  name        String
  price       Decimal @db.Decimal(10, 2)
  description String?

  // Solo para servicios (validar en app: requerido si type=SERVICE)
  durationMinutes Int?

  images ItemImage[]

  orderItems   OrderItem[]
  reservations Reservation[]

  scheduleWindows ServiceScheduleWindow[]
  scheduleBlocks  ServiceScheduleBlock[]

  // Ingredient consumption rules used for SIMPLE and RECIPE_BASED products.
  recipes Recipe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ habilita FK compuesta desde OrderItem (y permite validar "carrito 1 negocio")
  @@unique([id, businessId])
  @@index([businessId])
  @@index([type])
  @@index([status])
  @@index([businessId, inventoryMode])
}

model ItemImage {
  id     String @id @default(uuid())
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  url   String
  order Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, order])
  @@index([itemId])
}

// Physical stock unit tracked by inventory. All stock balances live here.
model Ingredient {
  id String @id @default(uuid())

  // Tenant owner for this physical stock unit.
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Human-readable ingredient/input name inside the business.
  name String

  // Operational lifecycle for stock inputs, independent from sellable Item.status.
  status IngredientStatus @default(ACTIVE)

  // Base unit used by recipes, Kardex, sale consumption, and currentStock.
  consumptionUnit String @db.VarChar(20)

  // Unit used when manually registering purchases or initial stock inputs.
  purchaseUnit String @db.VarChar(20)

  // Number of consumption units contained in one purchase unit.
  purchaseToConsumptionFactor Decimal @db.Decimal(20, 6)

  // Persisted current stock balance in consumptionUnit for fast sale validation.
  currentStock Decimal @default(0) @db.Decimal(20, 6)

  // Persisted weighted average cost per consumptionUnit for output valuation.
  averageCost Decimal @default(0) @db.Decimal(20, 6)

  // Recipe rows that consume this ingredient when items are sold.
  recipes Recipe[]

  // Kardex movements affecting this ingredient.
  inventoryMovements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@unique([id, businessId])
  @@index([businessId])
  @@index([businessId, status])
}

// Item-to-ingredient consumption rule used by SIMPLE and RECIPE_BASED inventory.
model Recipe {
  id String @id @default(uuid())

  // Tenant owner. Explicit to keep recipe queries and constraints tenant-scoped.
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Sellable item whose sale consumes this ingredient.
  itemId String
  item   Item   @relation(fields: [itemId, businessId], references: [id, businessId], onDelete: Cascade)

  // Physical stock unit consumed by the item.
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId, businessId], references: [id, businessId], onDelete: Restrict)

  // Ingredient quantity consumed per 1 sold item unit, in Ingredient.consumptionUnit.
  quantityRequired Decimal @db.Decimal(20, 6)

  // Marks ingredients that are part of configurable/optional consumption.
  isOptional Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, itemId, ingredientId])
  @@index([businessId])
  @@index([businessId, itemId])
  @@index([businessId, ingredientId])
}

// Ingredient-based Kardex entry. Purchases, sales, returns, and adjustments are recorded here.
model InventoryMovement {
  id String @id @default(uuid())

  // Tenant owner for this Kardex entry.
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Ingredient affected by this Kardex entry. Inventory remains ingredient-based only.
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId, businessId], references: [id, businessId], onDelete: Restrict)

  // Business reason for the stock movement and its input/output direction.
  type InventoryMovementType

  // Positive movement quantity in Ingredient.consumptionUnit. Direction comes from type.
  quantity Decimal @db.Decimal(20, 6)

  // Cost per Ingredient.consumptionUnit used for this movement.
  unitCost Decimal @db.Decimal(20, 6)

  // quantity * unitCost, preserved with six decimals for inventory valuation.
  totalValue Decimal @db.Decimal(20, 6)

  // Ingredient stock balance after this movement is applied.
  stockAfter Decimal @db.Decimal(20, 6)

  // Ingredient weighted average cost after this movement is applied.
  averageCostAfter Decimal @db.Decimal(20, 6)

  // High-level source category for traceability without adding Purchase models in Phase 1.
  referenceType InventoryReferenceType

  // Optional external/manual/source id for traceability.
  referenceId String?

  // Sale order that generated this movement, nullable for purchases and manual adjustments.
  orderId String?
  order   Order?  @relation(fields: [orderId, businessId], references: [id, businessId], onDelete: Restrict)

  // Sale line that generated this movement, nullable for purchases and manual adjustments.
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId, businessId], references: [id, businessId], onDelete: Restrict)

  // Human-readable detail or adjustment reason.
  detail String?

  // Business-effective timestamp for Kardex ordering and reports.
  occurredAt DateTime @default(now())

  // Immutable creation timestamp for audit ordering.
  createdAt DateTime @default(now())

  @@unique([businessId, orderItemId, ingredientId, type])
  @@index([businessId, occurredAt])
  @@index([businessId, ingredientId, occurredAt])
  @@index([businessId, type])
  @@index([businessId, referenceType, referenceId])
  @@index([businessId, orderId])
  @@index([businessId, orderItemId])
}

//
// ÓRDENES / VENTAS (carrito de 1 solo negocio por orden)
//

model Order {
  id String @id @default(uuid())

  publicToken String @unique @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  status OrderStatus @default(DRAFT)
  origin SaleOrigin  @default(MANUAL)

  // Cliente final sin registro
  customerName     String?
  customerWhatsapp String?
  note             String?
  paymentMethod    PaymentMethod @default(CASH)

  // Totales “congelados”
  total    Decimal @default(0) @db.Decimal(14, 2)
  currency String  @default("COP") @db.VarChar(3)

  // envío / documento (PDF)
  sentAt         DateTime?
  pdfUrl         String?
  pdfGeneratedAt DateTime?
  documentNumber String?

  items OrderItem[]

  accountingPostedAt DateTime?
  // Marks that inventory validation, stock decrement, and sale movements were posted.
  inventoryPostedAt  DateTime?
  // Ingredient-based Kardex movements generated by this sale.
  inventoryMovements InventoryMovement[]

  archived Boolean @default(false)

  // asiento automático generado por esta orden (opcional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, businessId])
  @@index([businessId, createdAt])
  @@index([businessId, inventoryPostedAt])
  @@index([status])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // se setea desde backend = Order.businessId
  businessId String

  itemId String
  // impide items de otro negocio en la misma orden
  item   Item   @relation(fields: [itemId, businessId], references: [id, businessId], onDelete: Restrict)

  quantity Int @default(1)

  // Snapshots para histórico/PDF (evita que cambien si se edita el catálogo)
  itemNameSnapshot        String
  itemTypeSnapshot        ItemType
  durationMinutesSnapshot Int?
  // Inventory behavior captured for this sale line when inventory is posted.
  inventoryModeSnapshot   InventoryMode?

  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  // Ingredient-based Kardex movements generated by this sale line.
  inventoryMovements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, businessId])
  @@index([orderId])
  @@index([orderId, itemId])
  @@index([itemId])
  @@index([businessId, itemId])
}

//
// RESERVAS (turnos) - con soporte para múltiples franjas por día vía ServiceScheduleWindow
//

model Reservation {
  id String @id @default(uuid())

  publicToken String? @unique @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  status ReservationStatus @default(PENDING)
  origin SaleOrigin        @default(MANUAL)

  // Cliente final sin registro
  customerName     String?
  customerWhatsapp String?
  note             String?
  paymentMethod    PaymentMethod @default(CASH)

  // Fecha del turno + rango horario (minutos del día)
  // Recomendación: date representa el "día" (normalizar a 00:00 en backend).
  date        DateTime
  startMinute Int
  endMinute   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  archived Boolean @default(false)

  // Evita duplicar exactamente el mismo slot para el mismo servicio
  @@unique([itemId, date, startMinute])
  @@index([businessId, date])
  @@index([itemId, date])
  @@index([status])
}

//
// HORARIOS DE SERVICIOS (soporta múltiples franjas en un mismo día)
//

model ServiceScheduleWindow {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // null => horario general del negocio.
  // set => horario específico de un servicio (Item.type=SERVICE).
  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  weekday Weekday

  // Minutos desde 00:00 (ej 540=09:00)
  startMinute Int
  endMinute   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, itemId, weekday, startMinute, endMinute])
  @@index([businessId, weekday])
  @@index([itemId, weekday])
}

model ServiceScheduleBlock {
  id String @id @default(uuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // bloqueos específicos de un servicio (opcional)
  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Bloqueo por fecha (normalizar a 00:00 en backend)
  date        DateTime
  // null/null => bloquea el día completo
  startMinute Int?
  endMinute   Int?

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, date])
  @@index([itemId, date])
}

//
// PUC (Opción A): Clase -> Grupo -> Cuenta -> Subcuenta (GLOBAL)
//

model PucClase {
  code String @id @db.VarChar(1) // ej "1"
  name String

  grupos PucGrupo[]
}

model PucGrupo {
  code String @id @db.VarChar(2) // ej "11"
  name String

  claseCode String   @db.VarChar(1)
  clase     PucClase @relation(fields: [claseCode], references: [code], onDelete: Restrict)

  cuentas PucCuenta[]

  @@index([claseCode])
}

model PucCuenta {
  code String @id @db.VarChar(4) // ej "1105"
  name String

  grupoCode String   @db.VarChar(2)
  grupo     PucGrupo @relation(fields: [grupoCode], references: [code], onDelete: Restrict)

  subcuentas          PucSubcuenta[]
  accountingMovements AccountingMovement[]

  @@index([grupoCode])
}

model PucSubcuenta {
  code String @id @db.VarChar(6) // ej "110505"
  name String

  cuentaCode String    @db.VarChar(4)
  cuenta     PucCuenta @relation(fields: [cuentaCode], references: [code], onDelete: Restrict)

  active Boolean @default(true)

  accountingMovements AccountingMovement[]

  @@index([cuentaCode])
}

enum MovementNature {
  DEBIT
  CREDIT
}

model AccountingMovement {
  id             String                       @id @default(cuid())
  businessId     String
  pucCuentaCode  String?                      @db.VarChar(4)
  pucSubcuentaId String?
  amount         Decimal                      @db.Decimal(18, 2)
  nature         MovementNature               @default(DEBIT)
  date           DateTime
  detail         String?
  originType     AccountingMovementOriginType
  originId       String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pucCuenta    PucCuenta?    @relation(fields: [pucCuentaCode], references: [code])
  pucSubcuenta PucSubcuenta? @relation(fields: [pucSubcuentaId], references: [code])

  @@index([businessId, date])
  @@index([pucCuentaCode])
  @@index([pucSubcuentaId])
}
